{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "groupName": "buf groups",
      "matchDatasources": ["npm"],
      "matchPackageNames": [
        "@bufbuild/protobuf",
        "@connectrpc/connect",
        "@connectrpc/connect-web"
      ]
    },
    {
      "groupName": "conform groups",
      "matchDatasources": ["npm"],
      "matchPackageNames": ["/^@conform-to\//"]
    },
    {
      "groupName": "fumadocs groups",
      "matchDatasources": ["npm"],
      "matchPackageNames": ["/^fumadocs-/"]
    },
    {
      "groupName": "prettier groups",
      "matchDatasources": ["npm"],
      "matchPackageNames": [
        "prettier",
        "prettier-plugin-tailwindcss",
        "@ianvs/prettier-plugin-sort-imports",
        "/^@prettier\//"
      ]
    }
  ]
}
