{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.?mise\\.toml$/",
        "/(^|/)\\.?mise/config\\.toml$/"
      ],
      "matchStrings": [
        "min_version\\s*=\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases"
    }
  ]
}
